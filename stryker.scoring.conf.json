{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-core-schema.json",
  "testRunner": "vitest",
  "coverageAnalysis": "off",
  "mutate": ["lib/huntStore.ts"],
  "ignorePatterns": [
    "**/*",
    "!lib/huntStore.ts",
    "!lib/__tests__/huntStore.test.ts",
    "!vitest.config.ts",
    "!vitest.setup.ts",
    "!tsconfig.json"
  ],
  "reporters": ["html", "clear-text", "progress"],
  "htmlReporter": {
    "fileName": "mutation-report/scoring/mutation.html"
  },
  "thresholds": {
    "high": 90,
    "low": 70,
    "break": 80
  },
  "concurrency": 2,
  "timeoutMS": 10000,
  "tsconfigFile": "tsconfig.json",
  "vitest": {
    "related": false,
    "configFile": "vitest.config.ts"
  }
}
