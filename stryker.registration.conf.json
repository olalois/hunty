{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-core-schema.json",
  "testRunner": "vitest",
  "coverageAnalysis": "off",
  "mutate": ["lib/contracts/player-registration.ts"],
  "ignorePatterns": [
    "**/*",
    "!lib/contracts/player-registration.ts",
    "!lib/contracts/config.ts",
    "!lib/contracts/errors.ts",
    "!lib/contracts/__tests__/player-registration.test.ts",
    "!lib/soroban/client.ts",
    "!lib/soroban/rpcRetry.ts",
    "!lib/types.ts",
    "!lib/stellarErrors.ts",
    "!vitest.config.ts",
    "!vitest.setup.ts",
    "!tsconfig.json"
  ],
  "reporters": ["html", "clear-text", "progress"],
  "htmlReporter": {
    "fileName": "mutation-report/registration/mutation.html"
  },
  "thresholds": {
    "high": 92,
    "low": 75,
    "break": 82
  },
  "concurrency": 2,
  "timeoutMS": 10000,
  "tsconfigFile": "tsconfig.json",
  "vitest": {
    "related": false,
    "configFile": "vitest.config.ts"
  }
}
